{
  "expo": {
    "name": "motofinance-mobile",
    "slug": "motofinance-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "scheme": "motofinancemobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D183D",
        "foregroundImage": "./assets/brand/android-icon-foreground.png",
        "backgroundImage": "./assets/brand/android-icon-background.png",
        "monochromeImage": "./assets/brand/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/splash-screen.png",
          "resizeMode": "cover",
          "backgroundColor": "#070D28",
          "dark": {
            "backgroundColor": "#070D28"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
